# Variables de entorno del BACKEND — ContaFlow CO
# Copia este archivo como .env y ajusta los valores

# ── Servidor ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Base de datos (Google Cloud SQL PostgreSQL) ───────────
DB_HOST=tu-ip-cloud-sql
DB_USER=tu-usuario
DB_PASSWORD=tu-contraseña-segura
DB_NAME=contaflow
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────
# Genera secretos con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRETO=cambia-este-secreto-en-produccion-minimo-32-caracteres
JWT_SECRETO_REFRESCO=cambia-este-secreto-refresco-en-produccion
JWT_EXPIRA_EN=8h

# ── CORS ──────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma
CORS_ORIGENES=http://localhost:5173,https://tudominio.com

# ── Email (para alertas y notificaciones futuras) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USUARIO=
SMTP_CONTRASENA=
CORREO_REMITENTE=noreply@contaflow.co
