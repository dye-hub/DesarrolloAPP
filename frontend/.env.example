# Variables de entorno del FRONTEND — ContaFlow CO
# Copia este archivo como .env y ajusta los valores

# URL base de la API del backend
VITE_API_URL=http://localhost:5000

# Nombre de la aplicación (usado en algunas vistas)
VITE_APP_NOMBRE=ContaFlow CO

# Entorno (development | production)
VITE_ENTORNO=development
